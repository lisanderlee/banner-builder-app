# Copy to .env.local — Supabase Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never prefix with NEXT_PUBLIC_ (would expose to the browser).
# Bypasses RLS — use only in trusted server code (scripts, webhooks, admin APIs).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
